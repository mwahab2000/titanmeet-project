# ─── Frontend (auto-populated by Lovable) ───
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_PUBLIC_ROOT_DOMAIN="titanmeet.com"

# ─── Supabase Edge Function Secrets ───
# Required for email sending (invitations, reminders, communications)
# GMAIL_USER=events@yourdomain.com
# GMAIL_APP_PASSWORD=your-google-app-password

# Required for auth email hook signature verification
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# Auto-managed by Supabase — do NOT set manually
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL=

# Optional — Lovable AI gateway (auto-provisioned)
# LOVABLE_API_KEY=

# Optional — Twilio for SMS/WhatsApp (not required for MVP)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── PayPal Payments ───
# Required for PayPal subscription payments
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# PAYPAL_SUCCESS_URL=https://yourdomain.com/dashboard/billing?payment=success
# PAYPAL_CANCEL_URL=https://yourdomain.com/dashboard/billing?payment=cancelled
# Per-plan PayPal subscription plan IDs (create in PayPal dashboard)
# PAYPAL_PLAN_ID_STARTER=P-xxxxx
# PAYPAL_PLAN_ID_PROFESSIONAL=P-xxxxx
# PAYPAL_PLAN_ID_ENTERPRISE=P-xxxxx
