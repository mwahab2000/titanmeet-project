# ─── Frontend (Vite — VITE_ prefix required) ───
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_PUBLIC_ROOT_DOMAIN="titanmeet.com"

# ─── Paddle Billing (frontend — publishable tokens only) ───
VITE_PADDLE_CLIENT_TOKEN=""
VITE_PADDLE_ENV="sandbox"
VITE_PADDLE_PRICE_STARTER_MONTHLY=""
VITE_PADDLE_PRICE_STARTER_ANNUAL=""
VITE_PADDLE_PRICE_PROFESSIONAL_MONTHLY=""
VITE_PADDLE_PRICE_PROFESSIONAL_ANNUAL=""
VITE_PADDLE_PRICE_ENTERPRISE_MONTHLY=""
VITE_PADDLE_PRICE_ENTERPRISE_ANNUAL=""

# ─── Supabase Edge Function Secrets ───
# Set these in: Supabase Dashboard → Settings → Edge Functions → Secrets
#
# PADDLE_API_KEY            — Paddle server-side API key
# PADDLE_WEBHOOK_SECRET     — Paddle webhook HMAC secret (MANDATORY)
# PADDLE_PRICE_STARTER_MONTHLY     — server-side price ID for plan resolution
# PADDLE_PRICE_STARTER_ANNUAL
# PADDLE_PRICE_PROFESSIONAL_MONTHLY
# PADDLE_PRICE_PROFESSIONAL_ANNUAL
# PADDLE_PRICE_ENTERPRISE_MONTHLY
# PADDLE_PRICE_ENTERPRISE_ANNUAL
# GMAIL_USER                — SMTP sender address
# GMAIL_APP_PASSWORD        — Google App Password for SMTP
# SEND_EMAIL_HOOK_SECRET    — Auth email hook verification
# OPENAI_API_KEY            — AI assistant
# GOOGLE_MAPS_API_KEY       — Google Places API (venue search + photos)
# AI_MODEL                  — OpenAI model name (e.g. gpt-4o-mini)
# VITE_APP_URL              — Public app URL for email links
# TWILIO_ACCOUNT_SID        — Twilio SID (for WhatsApp)
# TWILIO_AUTH_TOKEN          — Twilio auth token
# TWILIO_WHATSAPP_FROM       — WhatsApp sender (whatsapp:+14155238886)
# TWILIO_WHATSAPP_INVITE_TEMPLATE_SID
# TWILIO_WHATSAPP_REMINDER_TEMPLATE_SID
#
# Auto-managed by Supabase (do NOT set manually):
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_DB_URL

# ─── Sentry (frontend — error monitoring) ───
VITE_SENTRY_DSN=""
VITE_SENTRY_ENVIRONMENT="development"
VITE_SENTRY_TRACES_SAMPLE_RATE="0.1"
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0.05"
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="1.0"

# ─── Sentry (build-time only — source map upload) ───
# Set in CI/CD or Workspace Settings → Build Secrets
# SENTRY_AUTH_TOKEN           — Sentry API auth token
# SENTRY_ORG                  — Sentry organization slug
# SENTRY_PROJECT              — Sentry project slug
# SENTRY_RELEASE              — Optional release identifier
