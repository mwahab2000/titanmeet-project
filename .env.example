# ─── Frontend (auto-populated by Lovable) ───
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ─── Supabase Edge Function Secrets ───
# Required for email sending (invitations, reminders, communications)
# GMAIL_USER=events@yourdomain.com
# GMAIL_APP_PASSWORD=your-google-app-password

# Required for auth email hook signature verification
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# Auto-managed by Supabase — do NOT set manually
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL=

# Optional — Lovable AI gateway (auto-provisioned)
# LOVABLE_API_KEY=

# Optional — Twilio for SMS/WhatsApp (not required for MVP)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── Triple-A Crypto Payments ───
# Required for crypto subscription payments
# TRIPLEA_CLIENT_ID=your-triplea-client-id
# TRIPLEA_CLIENT_SECRET=your-triplea-client-secret
# TRIPLEA_MERCHANT_ID=your-triplea-merchant-key
# TRIPLEA_WEBHOOK_SECRET=your-webhook-secret
# TRIPLEA_SUCCESS_URL=https://yourdomain.com/dashboard/billing?payment=success
# TRIPLEA_CANCEL_URL=https://yourdomain.com/dashboard/billing?payment=cancelled
