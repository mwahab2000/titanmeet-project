# ─── Frontend (Vite — VITE_ prefix required) ───
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_PUBLIC_ROOT_DOMAIN="titanmeet.com"

# ─── Paddle Payments (frontend) ───
VITE_PADDLE_CLIENT_TOKEN=""
VITE_PADDLE_ENV="sandbox"
VITE_PADDLE_PRICE_STARTER_MONTHLY=""
VITE_PADDLE_PRICE_STARTER_ANNUAL=""
VITE_PADDLE_PRICE_PROFESSIONAL_MONTHLY=""
VITE_PADDLE_PRICE_PROFESSIONAL_ANNUAL=""
VITE_PADDLE_PRICE_ENTERPRISE_MONTHLY=""
VITE_PADDLE_PRICE_ENTERPRISE_ANNUAL=""

# ─── Supabase Edge Function Secrets ───
# Set these in: Supabase Dashboard → Settings → Edge Functions → Secrets
#
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# SEND_EMAIL_HOOK_SECRET=
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# OPENAI_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
#
# Auto-managed by Supabase (do NOT set manually):
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_DB_URL
