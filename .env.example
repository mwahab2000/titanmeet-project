# ─── Frontend (auto-populated by Lovable) ───
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_PUBLIC_ROOT_DOMAIN="titanmeet.com"

# ─── Paddle Payments ───
# Frontend (Vite):
# VITE_PADDLE_CLIENT_TOKEN=test_...   # "test_..." for sandbox, "live_..." for production
# VITE_PADDLE_ENV=sandbox             # "sandbox" or "production"
# Per-plan Paddle Price IDs (create in Paddle dashboard):
# VITE_PADDLE_PRICE_STARTER_ONETIME=pri_01abc...
# VITE_PADDLE_PRICE_STARTER_SUB=pri_01abc...
# VITE_PADDLE_PRICE_PROFESSIONAL_ONETIME=pri_01abc...
# VITE_PADDLE_PRICE_PROFESSIONAL_SUB=pri_01abc...
# VITE_PADDLE_PRICE_ENTERPRISE_ONETIME=pri_01abc...
# VITE_PADDLE_PRICE_ENTERPRISE_SUB=pri_01abc...

# Backend (Supabase Edge Function secrets):
# PADDLE_API_KEY=pdl_sdbx_...         # Server-side API key from Paddle dashboard
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_... # Webhook secret for signature verification

# ─── Supabase Edge Function Secrets ───
# Required for email sending (invitations, reminders, communications)
# GMAIL_USER=events@yourdomain.com
# GMAIL_APP_PASSWORD=your-google-app-password

# Required for auth email hook signature verification
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# Auto-managed by Supabase — do NOT set manually
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_URL=

# Optional — Lovable AI gateway (auto-provisioned)
# LOVABLE_API_KEY=

# Optional — Twilio for SMS/WhatsApp (not required for MVP)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── DEPRECATED: PayPal (replaced by Paddle) ───
# VITE_PAYPAL_CLIENT_ID=
# VITE_PAYPAL_ENV=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_API_BASE=
# PAYPAL_SUCCESS_URL=
# PAYPAL_CANCEL_URL=
# PAYPAL_PLAN_ID_STARTER=
# PAYPAL_PLAN_ID_PROFESSIONAL=
# PAYPAL_PLAN_ID_ENTERPRISE=
