# ── Stage 1: Build ──
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json* bun.lockb* ./
RUN npm ci --ignore-scripts

COPY . .

# Required build-time env vars (all VITE_ prefixed → baked into client bundle)
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_PUBLISHABLE_KEY
ARG VITE_SUPABASE_PROJECT_ID
ARG VITE_PUBLIC_ROOT_DOMAIN=titanmeet.com
ARG VITE_PADDLE_CLIENT_TOKEN
ARG VITE_PADDLE_ENV=sandbox
ARG VITE_PADDLE_PRICE_STARTER_MONTHLY
ARG VITE_PADDLE_PRICE_STARTER_ANNUAL
ARG VITE_PADDLE_PRICE_PROFESSIONAL_MONTHLY
ARG VITE_PADDLE_PRICE_PROFESSIONAL_ANNUAL
ARG VITE_PADDLE_PRICE_ENTERPRISE_MONTHLY
ARG VITE_PADDLE_PRICE_ENTERPRISE_ANNUAL

ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ENV VITE_SUPABASE_PUBLISHABLE_KEY=$VITE_SUPABASE_PUBLISHABLE_KEY
ENV VITE_SUPABASE_PROJECT_ID=$VITE_SUPABASE_PROJECT_ID
ENV VITE_PUBLIC_ROOT_DOMAIN=$VITE_PUBLIC_ROOT_DOMAIN
ENV VITE_PADDLE_CLIENT_TOKEN=$VITE_PADDLE_CLIENT_TOKEN
ENV VITE_PADDLE_ENV=$VITE_PADDLE_ENV
ENV VITE_PADDLE_PRICE_STARTER_MONTHLY=$VITE_PADDLE_PRICE_STARTER_MONTHLY
ENV VITE_PADDLE_PRICE_STARTER_ANNUAL=$VITE_PADDLE_PRICE_STARTER_ANNUAL
ENV VITE_PADDLE_PRICE_PROFESSIONAL_MONTHLY=$VITE_PADDLE_PRICE_PROFESSIONAL_MONTHLY
ENV VITE_PADDLE_PRICE_PROFESSIONAL_ANNUAL=$VITE_PADDLE_PRICE_PROFESSIONAL_ANNUAL
ENV VITE_PADDLE_PRICE_ENTERPRISE_MONTHLY=$VITE_PADDLE_PRICE_ENTERPRISE_MONTHLY
ENV VITE_PADDLE_PRICE_ENTERPRISE_ANNUAL=$VITE_PADDLE_PRICE_ENTERPRISE_ANNUAL

RUN npm run build

# ── Stage 2: Serve ──
FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
